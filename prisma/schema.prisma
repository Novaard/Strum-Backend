generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Device {
  id             String      @id // device_id dari ESP32
  ipAddress      String?
  lastSeen       DateTime    @default(now())
  status         String      @default("off") // off, idle, on_duty
  voltase        Int         @default(0)
  arus           Int         @default(0)
  suhu           Int         @default(0)
  kelembapan     Int         @default(0)
  thresholdIdle  Int         @default(0)
  thresholdDuty  Int         @default(0)
  logs           DeviceLog[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model DeviceLog {
  id          String   @id @default(uuid())
  deviceId    String
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  timestamp   DateTime
  voltase     Int
  arus        Int
  status      String
  suhu        Int
  kelembapan  Int
  createdAt   DateTime @default(now())

  @@index([deviceId])
  @@index([timestamp]) // Index untuk optimasi query statistik berdasarkan waktu
}